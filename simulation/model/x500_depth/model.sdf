<?xml version="1.0" encoding="UTF-8"?>
<sdf version='1.9'>
  <model name='x500_depth'>
    
    <include merge='true'><uri>x500</uri></include>
    <include merge='true'>
      <uri>model://OakD-Lite</uri>
      <pose>.12 .03 .242 0 0 0</pose>
    </include>

    <joint name="CameraJoint" type="fixed">
      <parent>base_link</parent>
      <child>camera_link</child>
      <pose relative_to="base_link">.12 .03 .242 0 1.57 0</pose>
    </joint>

    <link name="bottom_camera_link">
      <pose relative_to="base_link">0.15 0 -0.02 0 1.5708 0</pose> 
      <inertial>
        <mass>0.01</mass>
        <inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia>
      </inertial>
      <sensor name="bottom_camera" type="camera">
        <camera>
          <horizontal_fov>1.57</horizontal_fov>
          <image><width>640</width><height>480</height></image>
          <clip><near>0.1</near><far>100</far></clip>
        </camera>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <visualize>true</visualize>
        <topic>/bottom_camera/image_raw</topic>
      </sensor>
    </link>
    <joint name="bottom_camera_joint" type="fixed">
      <parent>base_link</parent>
      <child>bottom_camera_link</child>
    </joint>

    <link name="arm_link_1">
      <pose relative_to="base_link">0 0 -0.05 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia>
      </inertial>
      <collision name="collision">
        <pose>0 0 -0.045 0 0 0</pose> <geometry><box><size>0.03 0.03 0.09</size></box></geometry>
      </collision>
      <visual name="visual">
        <pose>0 0 -0.045 0 0 0</pose>
        <geometry><box><size>0.03 0.03 0.09</size></box></geometry>
        <material><ambient>0 0 1 1</ambient><diffuse>0 0 1 1</diffuse></material>
      </visual>
    </link>
    <joint name="arm_mount_joint" type="fixed">
      <parent>base_link</parent>
      <child>arm_link_1</child>
    </joint>

    <joint name="elbow_joint" type="revolute">
      <parent>arm_link_1</parent>
      <child>arm_link_2</child>
      <pose relative_to="arm_link_1">0 0 -0.09 0 0 0</pose> <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-3.1415</lower><upper>3.1415</upper><effort>50.0</effort></limit>
        <dynamics><damping>0.1</damping><friction>0.1</friction></dynamics>
      </axis>
    </joint>
    <link name="arm_link_2">
      <pose relative_to="elbow_joint">0 0 0 0 1.5708 0</pose> <inertial>
        <mass>0.2</mass>
        <inertia><ixx>0.001</ixx><iyy>0.0005</iyy><izz>0.0005</izz></inertia>
      </inertial>
      <collision name="collision">
        <pose>0 0 0.075 0 0 0</pose>
        <geometry><box><size>0.03 0.03 0.15</size></box></geometry>
      </collision>
      <visual name="visual">
        <pose>0 0 0.075 0 0 0</pose>
        <geometry><box><size>0.03 0.03 0.15</size></box></geometry>
        <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material>
      </visual>
    </link>

    <joint name="wrist_joint" type="revolute">
      <parent>arm_link_2</parent>
      <child>gripper_base</child>
      <pose relative_to="arm_link_2">0 0 0.15 0 0 0</pose> <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1.5708</lower><upper>1.5708</upper><effort>20.0</effort></limit>
        <dynamics><damping>0.1</damping><friction>0.1</friction></dynamics>
      </axis>
    </joint>
    <link name="gripper_base">
      <pose relative_to="wrist_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia>
      </inertial>
    </link>

    <link name="left_finger">
      <pose relative_to="gripper_base">0 0.08 0.06 0 0 0</pose> <inertial><mass>0.05</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia></inertial>
      <collision name="collision"><geometry><box><size>0.02 0.01 0.12</size></box></geometry></collision>
      <visual name="visual"><geometry><box><size>0.02 0.01 0.12</size></box></geometry>
        <material><ambient>1 1 0 1</ambient><diffuse>1 1 0 1</diffuse></material>
      </visual>
      <sensor name='left_contact_sensor' type='contact'>
        <contact><collision>collision</collision></contact>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <topic>/contact/left_finger</topic>
      </sensor>
    </link>
    <joint name="left_finger_joint" type="prismatic">
      <parent>gripper_base</parent>
      <child>left_finger</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-0.10</lower><upper>0.0</upper><effort>30.0</effort></limit> <dynamics><damping>0.1</damping></dynamics>
      </axis>
    </joint>

    <link name="right_finger">
      <pose relative_to="gripper_base">0 -0.08 0.06 0 0 0</pose> <inertial><mass>0.05</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia></inertial>
      <collision name="collision"><geometry><box><size>0.02 0.01 0.12</size></box></geometry></collision>
      <visual name="visual"><geometry><box><size>0.02 0.01 0.12</size></box></geometry>
        <material><ambient>1 1 0 1</ambient><diffuse>1 1 0 1</diffuse></material>
      </visual>
      <sensor name='right_contact_sensor' type='contact'>
        <contact><collision>collision</collision></contact>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <topic>/contact/right_finger</topic>
      </sensor>
    </link>
    <joint name="right_finger_joint" type="prismatic">
      <parent>gripper_base</parent>
      <child>right_finger</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>0.0</lower><upper>0.10</upper><effort>30.0</effort></limit> <dynamics><damping>0.1</damping></dynamics>
      </axis>
    </joint>

    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>elbow_joint</joint_name>
      <topic>/model/x500_depth_0/joint/elbow_joint/cmd_pos</topic>
      <p_gain>10.0</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>0.1</d_gain>
      <cmd_max>20.0</cmd_max>
      <cmd_min>-20.0</cmd_min>
    </plugin>

    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>wrist_joint</joint_name>
      <topic>/model/x500_depth_0/joint/wrist_joint/cmd_pos</topic>
      <p_gain>5.0</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>0.1</d_gain>
      <cmd_max>10.0</cmd_max>
      <cmd_min>-10.0</cmd_min>
    </plugin>

    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>left_finger_joint</joint_name>
      <topic>/model/x500_depth_0/joint/left_finger_joint/cmd_pos</topic>
      <p_gain>2.0</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>0.01</d_gain>
      <cmd_max>5.0</cmd_max>
      <cmd_min>-5.0</cmd_min>
    </plugin>

    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>right_finger_joint</joint_name>
      <topic>/model/x500_depth_0/joint/right_finger_joint/cmd_pos</topic>
      <p_gain>2.0</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>0.01</d_gain>
      <cmd_max>5.0</cmd_max>
      <cmd_min>-5.0</cmd_min>
    </plugin>

    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"/>

  </model>
</sdf>
